<!-- Test workflow -->
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OccasionReminder.MainPage"
             Title="Occasion Reminder">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Label 
                Text="Occasion Reminder"
                FontSize="30"
                HorizontalOptions="Center"
                FontAttributes="Bold"/>

            <Button
                Text="Add Occasion"
                FontSize="18"
                HeightRequest="50"
                Clicked="AddClicked"/>

            <Button
                Text="View Upcoming Occasions"
                FontSize="18"
                HeightRequest="50"
                Clicked="ViewClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
